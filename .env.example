# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — it stays on your machine only.

# --- Database (Prisma) ---
DATABASE_URL="file:./dev.db"

# --- Auth.js / NextAuth ---
# Random string used to sign session cookies. Generate with:
#   openssl rand -base64 32
# (Or in PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 })))
AUTH_SECRET=

# The URL where the app runs. localhost:3000 in dev, your real domain in prod.
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth ---
# Google Cloud Console → Alpha Assist → APIs & Services → Credentials → Web application
# Add http://localhost:3000/api/auth/callback/google as an authorized redirect URI.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- LLM brain (OpenRouter) ---
# Get keys at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any model ID from https://openrouter.ai/models
MODEL=deepseek/deepseek-v4-pro
