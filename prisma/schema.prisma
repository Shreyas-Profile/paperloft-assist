generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth is JWT-only — no User/Account/Session rows. The email in the session
// cookie is the identifier used by every row below (mirrors what the old
// DynamoDB adapter did with pk = "USER#<email>").

model Conversation {
  id        String   @id
  userEmail String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([userEmail, updatedAt(sort: Desc)])
}

model Message {
  id             String       @id
  conversationId String
  role           String       // "user" | "assistant" | "system"
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Third-party integration tokens (LinkedIn, Telegram, GitHub, etc.).
// `data` is a JSON blob shaped by the provider (see src/lib/integrations.ts).

model Integration {
  id        String   @id @default(cuid())
  userEmail String
  provider  String   // "linkedin" | "telegram" | "github" | …
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userEmail, provider])
  @@index([userEmail])
}

// Inverse-lookup row so `findUserByTelegramChatId` is a single indexed query
// rather than a full Integration scan.
model TelegramChatMap {
  chatId    BigInt   @id
  userEmail String
  createdAt DateTime @default(now())
}

// Per-user skill enablement. Skills marketplace shows a toggle per skill;
// this table records who has opted in. Absence of a row = disabled.
// skillId matches SKILLS[].id in src/app/skills/page.tsx.
model EnabledSkill {
  userEmail String
  skillId   String
  enabledAt DateTime @default(now())

  @@id([userEmail, skillId])
  @@index([userEmail])
}

// Sub-account credentials paperloft provisions on external MCP skill servers
// (docs.regiq.in, cron.regiq.in, ...) on behalf of paperloft users.
// One row per (userEmail, skillId) once the user has enabled that skill.
// `remoteApiKey` is stored plaintext — the skill server only knows its sha256
// hash and cannot re-derive the raw. Rotating on the skill side means we
// need to re-provision here.
model SkillConnection {
  userEmail     String
  skillId       String    // e.g. "docs_mcp"
  remoteUserId  String    // id of the User row on the remote MCP server
  remoteApiKey  String    // raw Bearer token to call the remote MCP with
  provisionedAt DateTime  @default(now())

  @@id([userEmail, skillId])
  @@index([userEmail])
}

// User-added ("bring your own") MCP skills. Each row is one remote MCP
// endpoint the user has plugged in — a URL + auth headers + a cached copy
// of the tool descriptors we discovered on save. Headers are stored
// AES-256-GCM encrypted with USER_SKILL_ENCRYPTION_KEY; they contain the
// user's third-party API keys and must never appear plaintext at rest.
//
// Design notes:
//   - Tools are re-discovered on save (and manual "refresh"), NOT on every
//     chat turn, so the LLM sees a stable toolbelt even if the remote MCP
//     is momentarily down. `tools` caches [{ name, description, inputSchema }].
//   - `enabled` gates whether the tools flow into the LLM's toolbelt.
//   - Hard cap of 20 rows per userEmail — enforced at the API layer.
model UserSkill {
  id               String   @id @default(cuid())
  userEmail        String
  name             String   // user-chosen slug like "my-jira" — used in the tool prefix
  mcpUrl           String   // e.g. https://mcp.example.com/api/mcp
  headersEncrypted String?  @db.Text  // ciphertext of JSON.stringify(headersObject)
  tools            Json     @default("[]") // cached [{ name, description, inputSchema }]
  enabled          Boolean  @default(true)
  addedAt          DateTime @default(now())
  lastVerifiedAt   DateTime?

  @@unique([userEmail, name])
  @@index([userEmail])
}

// ---- Reminders skill (vendored from Pakki10/nova-reminders MIT) ----------
// Replaces the earlier flat `Reminder` model. `userId` here stores the
// user's email — paperloft-assist identifies users by JWT email and
// nova-reminders is agnostic about the id format.

model Reminder {
  id                String    @id @default(cuid())
  userId            String
  type              String    @default("general") // general | medication | appointment
  title             String
  description       String?
  dueAt             DateTime
  recurrence        String    @default("none") // none | hourly | daily | weekdays | weekly | monthly | yearly | cron:<expr>
  recurrenceEnd     DateTime?
  status            String    @default("pending") // pending | sent | cancelled | draft
  ackMode           String    @default("tap") // none | tap | reply
  snoozeOffer       Int[]     @default([])
  escalateAfterMin  Int       @default(0)
  prescriptionId    String?
  telegramChatId    String?
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  instances         ReminderInstance[]
  prescription      Prescription?      @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([dueAt, status])
  @@map("reminders")
}

model ReminderInstance {
  id                    String    @id @default(cuid())
  reminderId            String
  userId                String
  scheduledFor          DateTime
  firedAt               DateTime?
  ackState              String    @default("pending") // pending | acked | snoozed | missed | skipped
  ackButtonId           String?
  ackAt                 DateTime?
  snoozedToInstanceId   String?
  channels              String[]  @default([])
  escalatedAt           DateTime?

  reminder              Reminder  @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([userId, ackState])
  @@index([scheduledFor, ackState])
  @@index([reminderId, scheduledFor])
  @@map("reminder_instances")
}

model Prescription {
  id                   String    @id @default(cuid())
  userId               String
  patientName          String?
  doctorName           String?
  doctorRegistrationNo String?
  hospitalOrClinic     String?
  prescriptionDate     DateTime?
  followUpDate         DateTime?
  diagnoses            String[]  @default([])
  advice               String?
  medications          Json      @default("[]")
  fileRef              String?
  starred              Boolean   @default(false)
  extractedText        String?   @db.Text
  createdAt            DateTime  @default(now())

  reminders            Reminder[]

  @@index([userId, createdAt])
  @@index([userId, starred])
  @@map("prescriptions")
}

model UserChannelPref {
  userId               String   @id
  telegramChatId       String?
  whatsappNumber       String?
  defaultChannel       String   @default("whatsapp") // paperloft-assist default = WhatsApp (wasender wired)
  fallbackChannel      String?
  askAckOnGeneral      Boolean  @default(false)
  defaultSnoozeMinutes Int[]    @default([5, 10])
  updatedAt            DateTime @updatedAt

  @@map("user_channel_prefs")
}

// Post-signup Telegram link. Populated by /api/telegram/bot-webhook when the
// user opens @PaperloftAssistantBot with a /start <nonce> deep-link generated
// while they were signed into paperloft.uk. The nonce proves the two sides
// (web session + Telegram user) belong to the same person, unspoofable.
model TelegramLink {
  userEmail String   @id
  chatId    String
  username  String?
  firstName String?
  linkedAt  DateTime @default(now())

  @@index([chatId])
  @@map("telegram_links")
}

// Short-lived nonces used to prove `web-session ↔ telegram-chat` linkage.
// /api/telegram/link-init issues one; the bot webhook consumes it on
// /start <nonce>. 10-min TTL, single-use.
model TelegramLinkNonce {
  nonce     String   @id
  userEmail String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@map("telegram_link_nonces")
}

// Phone → Telegram chatId mapping. Written by the bot webhook when a user
// taps "Share Contact" — Telegram itself signs the phone number, so this is
// how we trust that chatId X really belongs to phone +Y. Anyone can spoof
// a chatId to us; nobody can spoof a Telegram-verified phone.
model TelegramPhoneMap {
  phone      String   @id                       // E.164, e.g. "+447404660489"
  chatId     String                             // Telegram chat_id (numeric, stored as string)
  firstName  String?
  username   String?
  verifiedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chatId])
  @@map("telegram_phone_map")
}

// Short-lived OTP codes for WhatsApp / Telegram sign-in.
// `identifier` = phone number (E.164) for BOTH providers. For Telegram we
// look up the chatId via TelegramPhoneMap. Consumed once via
// /api/auth/otp/verify.
model SignInCode {
  id         String    @id @default(cuid())
  provider   String    // "whatsapp" | "telegram"
  identifier String    // phone (E.164) or telegram chatId
  code       String    // 6-digit numeric
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([provider, identifier])
  @@index([expiresAt])
  @@map("sign_in_codes")
}
